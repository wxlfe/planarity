rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userFields() {
      return [
        'currentLevel',
        'appStoreReviewPromptedAt',
        'displayName',
        'friends',
        'hiddenDisplayNameUserIds',
        'lastPlayed',
        'lastRankingSummaryShownFor',
        'lifetimeScore',
        'locked',
        'score',
        'tutorialCompleted',
      ];
    }

    function requiredUserFields() {
      return [
        'currentLevel',
        'displayName',
        'friends',
        'lastPlayed',
        'lifetimeScore',
        'locked',
        'score',
      ];
    }

    function validDisplayName(value) {
      return value is string &&
        value.size() > 0 &&
        value.size() <= 40;
    }

    function validLastPlayed(value) {
      return value is string &&
        (
          value == '' ||
          value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        );
    }

    function validFriends(value) {
      return value is list && value.size() <= 100;
    }

    function validHiddenDisplayNameUserIds(data) {
      return !('hiddenDisplayNameUserIds' in data.keys()) ||
        (
          data.hiddenDisplayNameUserIds is list &&
          data.hiddenDisplayNameUserIds.size() <= 250
        );
    }

    function validOptionalTutorialCompleted(data) {
      return !('tutorialCompleted' in data.keys()) ||
        data.tutorialCompleted is bool;
    }

    function validOptionalAppStoreReviewPromptedAt(data) {
      return !('appStoreReviewPromptedAt' in data.keys()) ||
        validLastPlayed(data.appStoreReviewPromptedAt);
    }

    function validOptionalLastRankingSummaryShownFor(data) {
      return !('lastRankingSummaryShownFor' in data.keys()) ||
        validLastPlayed(data.lastRankingSummaryShownFor);
    }

    function validUserDocument(data) {
      return data.keys().hasOnly(userFields()) &&
        data.keys().hasAll(requiredUserFields()) &&
        validDisplayName(data.displayName) &&
        data.currentLevel is int &&
        data.currentLevel >= 1 &&
        data.friends is list &&
        validFriends(data.friends) &&
        validHiddenDisplayNameUserIds(data) &&
        validOptionalTutorialCompleted(data) &&
        validOptionalAppStoreReviewPromptedAt(data) &&
        validOptionalLastRankingSummaryShownFor(data) &&
        validLastPlayed(data.lastPlayed) &&
        data.locked is bool &&
        data.lifetimeScore is int &&
        data.lifetimeScore >= 0 &&
        data.score is int &&
        data.score >= 0;
    }

    function validOwnerCreate(uid) {
      return isOwner(uid) && validUserDocument(request.resource.data);
    }

    function validOwnerUpdate(uid) {
      return isOwner(uid) &&
        validUserDocument(request.resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(userFields()) &&
        request.resource.data.lifetimeScore >= resource.data.lifetimeScore;
    }

    function validReciprocalFriendUpdate(uid) {
      return signedIn() &&
        request.auth.uid != uid &&
        validUserDocument(request.resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) &&
        (
          (
            request.auth.uid in request.resource.data.friends &&
            !(request.auth.uid in resource.data.friends)
          ) ||
          (
            !(request.auth.uid in request.resource.data.friends) &&
            request.auth.uid in resource.data.friends
          )
        );
    }

    function reportFields() {
      return [
        'createdAt',
        'details',
        'reason',
        'reportedDisplayName',
        'reportedUid',
        'reporterUid',
        'source',
        'status',
      ];
    }

    function validReportCreate() {
      return signedIn() &&
        request.resource.data.keys().hasOnly(reportFields()) &&
        request.resource.data.keys().hasAll(reportFields()) &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.reportedUid is string &&
        request.resource.data.reportedUid != request.auth.uid &&
        request.resource.data.reportedDisplayName is string &&
        request.resource.data.reportedDisplayName.size() > 0 &&
        request.resource.data.reportedDisplayName.size() <= 80 &&
        request.resource.data.reason in [
          'inappropriate_display_name',
          'abuse',
          'impersonation',
          'spam',
          'other'
        ] &&
        request.resource.data.details is string &&
        request.resource.data.details.size() <= 1000 &&
        request.resource.data.source in [
          'friends',
          'friends_leaderboard',
          'global_leaderboard'
        ] &&
        request.resource.data.status == 'open' &&
        request.resource.data.createdAt == request.time;
    }

    function validDailyScoreEntry(dayKey, uid) {
      return signedIn() &&
        request.auth.uid == uid &&
        dayKey.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
        request.resource.data.keys().hasOnly([
          'displayName',
          'locked',
          'score',
          'uid',
          'updatedAt'
        ]) &&
        request.resource.data.keys().hasAll([
          'displayName',
          'locked',
          'score',
          'uid',
          'updatedAt'
        ]) &&
        request.resource.data.uid == uid &&
        validDisplayName(request.resource.data.displayName) &&
        request.resource.data.locked is bool &&
        request.resource.data.score is int &&
        request.resource.data.score >= 0 &&
        request.resource.data.updatedAt == request.time;
    }

    match /users/{uid} {
      // Global and friends leaderboards read from this collection. The current
      // app stores public leaderboard fields and friend IDs together here.
      allow read: if true;

      allow create: if validOwnerCreate(uid);
      allow update: if validOwnerUpdate(uid) || validReciprocalFriendUpdate(uid);
      allow delete: if isOwner(uid);
    }

    match /reports/{reportId} {
      allow create: if validReportCreate();
      allow read, update, delete: if false;
    }

    match /dailyScores/{dayKey}/entries/{uid} {
      allow read: if true;
      allow create, update: if validDailyScoreEntry(dayKey, uid);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
